PORT=5000
NODE_ENV=development

# Comma-separated browser origins allowed by CORS (your Vercel app + locals if needed)
CLIENT_ORIGINS=https://shoe-testing-frontend.vercel.app

# Bug report email configuration
BUG_REPORT_TO_EMAIL=vaibhav.kaushik@ttsys.in
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
